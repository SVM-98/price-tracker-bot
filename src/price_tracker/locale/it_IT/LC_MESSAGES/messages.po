msgid "⛔ Admin-only command."
msgstr "⛔ Solo l'amministratore può usare questo comando."

#: src/price_tracker/bot/handlers/auth.py:30
msgid ""
"❌ Usage: /adduser &lt;telegram_id&gt;\n"
"\n"
"The user must send /start to the bot first to obtain their ID."
msgstr ""
"❌ Uso: /adduser &lt;telegram_id&gt;\n"
"\n"
"L'utente deve prima inviare /start al bot per ottenere il suo ID."

