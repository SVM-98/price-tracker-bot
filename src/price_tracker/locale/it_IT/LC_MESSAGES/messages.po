#: src/price_tracker/bot/handlers/auth.py:55
#, python-brace-format
msgid ""
"✅ User <code>{tg_id}</code> added.\n"
"They can now use the bot by sending /start."
msgstr ""
"✅ Utente <code>{tg_id}</code> aggiunto!\n"
"Ora può usare il bot inviando /start."

#: src/price_tracker/bot/handlers/auth.py:64
msgid ""
"🎉 You have been authorized to use Price Tracker Bot.\n"
"Send /start to begin."
msgstr ""
"🎉 Sei stato autorizzato a usare il Price Tracker Bot!\n"
"Invia /start per iniziare."

