#: src/price_tracker/bot/decorators.py:70
#, python-brace-format
msgid ""
"⛔ You are not authorized.\n"
"Your Telegram ID: <code>{tg_id}</code>\n"
"\n"
"Ask the administrator to add you with:\n"
"<code>/adduser {tg_id}</code>"
msgstr ""
"⛔ Non sei autorizzato.\n"
"Il tuo ID Telegram è: <code>{tg_id}</code>\n"
"\n"
"Chiedi all'amministratore di aggiungerti con:\n"
"<code>/adduser {tg_id}</code>"

