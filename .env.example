# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # Get from @BotFather
ALLOWED_USERS=                     # Comma-separated Telegram user IDs (e.g. 123456789,987654321)
                                   # Leave empty to allow everyone (NOT recommended)

# ── Check Interval ───────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=360         # How often to check prices (default 360 = 6h)
                                   # Override at runtime via /set_interval <minutes>

# ── Threshold Defaults ───────────────────────────────────────────
DEFAULT_THRESHOLD_TYPE=percentage  # 'percentage' or 'absolute'
DEFAULT_THRESHOLD_VALUE=10         # Default trigger for new products (10%)

# ── Notifications ────────────────────────────────────────────────
NOTIFICATION_COOLDOWN_HOURS=24     # Min hours between notifications for the same product

# ── Scraping ─────────────────────────────────────────────────────
MAX_CONSECUTIVE_ERRORS=10          # Errors before deactivating a product
CHECK_DELAY_SECONDS=5              # Seconds between products in a sweep
REQUEST_TIMEOUT=30                 # HTTP request timeout in seconds

# ── Database ─────────────────────────────────────────────────────
DATABASE_PATH=/data/pricetracker.db

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO                     # DEBUG for development, INFO for production

# ── Locale (Plan 3 — i18n) ───────────────────────────────────────
# Default locale (en, it). Per-user override is auto-detected from Telegram
# language_code; this is the server-side fallback when no per-user lang is set.
LOCALE=en
